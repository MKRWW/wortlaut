[importlinter]
root_package = wortlaut

# R-ARCH-02: Abhängigkeiten zeigen nach innen. Der Kern (ingest/evidence/store/
# retrieval) darf den Serving-/Output-Layer NIE importieren. Verhindert u.a., dass
# LLM-/Ausgabe-Logik in den Beweis-Kern sickert.
[importlinter:contract:core-unabhaengig-von-serving]
name = Kern importiert nicht den Serving-Layer
type = forbidden
source_modules =
    wortlaut.ingest
    wortlaut.evidence
    wortlaut.store
    wortlaut.retrieval
    wortlaut.pipeline
forbidden_modules =
    wortlaut.serving

# Ticket #7/#43: pipeline ORCHESTRIERT (darf ingest/evidence/archive/store importieren);
# die INNEREN Layer importieren pipeline nie (Abhängigkeiten zeigen nach innen, R-ARCH-02).
# Ausnahme (#43): `serving` ist der ÄUSSERSTE Layer und darf `pipeline` konsumieren
# (reuse verify_source, #8) — serving → pipeline → store/evidence/archive bleibt azyklisch.
# Dass serving keinen LLM-/Ausgabetext erzeugt, erzwingt check_no_llm_output (R-SEC-04).
[importlinter:contract:innere-layer-importieren-nicht-pipeline]
name = Innere Layer importieren den Pipeline-Layer nicht
type = forbidden
source_modules =
    wortlaut.ingest
    wortlaut.evidence
    wortlaut.store
    wortlaut.retrieval
    wortlaut.archive
forbidden_modules =
    wortlaut.pipeline

# Spec 0004 §3: wortlaut.archive ist ein eigener Infrastruktur-Layer und importiert
# keinen anderen wortlaut-Layer (wird nur von wortlaut.pipeline konsumiert, #7).
[importlinter:contract:archive-ist-unabhaengig]
name = Archive-Layer importiert keinen anderen wortlaut-Layer
type = forbidden
source_modules =
    wortlaut.archive
forbidden_modules =
    wortlaut.ingest
    wortlaut.evidence
    wortlaut.store
    wortlaut.retrieval
    wortlaut.serving
