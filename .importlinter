[importlinter]
root_package = wortlaut

# R-ARCH-02: Abhängigkeiten zeigen nach innen. Der Kern (ingest/evidence/store/
# retrieval) darf den Serving-/Output-Layer NIE importieren. Verhindert u.a., dass
# LLM-/Ausgabe-Logik in den Beweis-Kern sickert.
[importlinter:contract:core-unabhaengig-von-serving]
name = Kern importiert nicht den Serving-Layer
type = forbidden
source_modules =
    wortlaut.ingest
    wortlaut.evidence
    wortlaut.store
    wortlaut.retrieval
    wortlaut.pipeline
forbidden_modules =
    wortlaut.serving

# Ticket #7: pipeline ORCHESTRIERT (darf ingest/evidence/archive/store importieren),
# aber niemand importiert pipeline — Abhängigkeiten zeigen nach innen (R-ARCH-02).
[importlinter:contract:niemand-importiert-pipeline]
name = Niemand importiert den Pipeline-Layer
type = forbidden
source_modules =
    wortlaut.ingest
    wortlaut.evidence
    wortlaut.store
    wortlaut.retrieval
    wortlaut.archive
    wortlaut.serving
forbidden_modules =
    wortlaut.pipeline

# Spec 0004 §3: wortlaut.archive ist ein eigener Infrastruktur-Layer und importiert
# keinen anderen wortlaut-Layer (wird nur von wortlaut.pipeline konsumiert, #7).
[importlinter:contract:archive-ist-unabhaengig]
name = Archive-Layer importiert keinen anderen wortlaut-Layer
type = forbidden
source_modules =
    wortlaut.archive
forbidden_modules =
    wortlaut.ingest
    wortlaut.evidence
    wortlaut.store
    wortlaut.retrieval
    wortlaut.serving
